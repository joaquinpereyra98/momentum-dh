<li
  class="token-combatant {{cssClass}}"
  data-turn="{{turn}}"
  data-flip-id="momentum-token-combatant-{{combatant.id}}"
  data-combatant-id="{{combatant.id}}"
>
  <img
    src="{{combatant.img}}"
    alt="{{combatant.name}}"
    data-action="combatantClick"
    class="combatant-img"
  />
    {{#if isRequesting}}
      <div class="request-orbit" data-orbit-id="{{combatant.id}}">
        <div class="satellite"></div>
      </div>
    {{/if}}

    {{#if userIsGM}}
      <a
        class="icon spotlight-anchor"
        data-action="setSpotlight"
        data-tooltip="Give The Spotlight"
        data-tooltip-direction="{{ifThen combatant.isNPC 'LEFT' 'RIGHT'}}"
      >
        <i
          class="fa-solid
            {{ifThen combatant.isNPC 'fa-skull' 'fa-hand-sparkles'}}"
        ></i>
      </a>
    {{else}}
      {{#if combatant.actor.isOwner}}
        <a
          class="icon spotlight-anchor"
          data-action="requestSpotlight"
          data-tooltip="Request Spotlight"
          data-tooltip-direction="RIGHT"
        >
          <i class="fa-solid fa-hand"></i>
        </a>
      {{/if}}
    {{/if}}
</li>